            "https://joola.com.vn/images/1102/thumbs/joola-ra-mat-vot-pickleball-pro-iv-va-agassi-pro-duoc-chung-nhan-kep-w900.webp",
            "/blog/chung-nhan-kep-agassi-pro-va-pro-iv"
        )
    };

    private RenderFragment SectionHeading(string eyebrow, string title, string buttonText, string buttonUrl)
    {
        return @<div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
            <div>
                <p class="text-xs font-black tracking-[0.3em] text-[#d71920] uppercase">
                    @eyebrow
                </p>

                <h2 class="mt-2 text-4xl font-black tracking-[-0.06em] uppercase md:text-5xl">
                    @title
                </h2>
            </div>

            <a href="@buttonUrl" class="inline-flex w-fit rounded-full bg-[#d71920] !px-5 !py-3 text-xs font-black tracking-wide !text-white uppercase transition hover:bg-neutral-950">
                @buttonText
            </a>
        </div>;
    }

    private RenderFragment ProductCard(ProductItem product)
    {
        return @<article class="group relative overflow-hidden rounded-[1.75rem] border border-neutral-200 bg-white text-neutral-950 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            @if (product.Discount > 0)
            {
                <div class="absolute top-4 left-4 z-10 rounded-full bg-[#d71920] !px-3 !py-1 text-xs font-black !text-white">
                    -@product.Discount%
                </div>
            }

            <div class="absolute top-4 right-4 z-10 rounded-full bg-neutral-950 !px-3 !py-1 text-xs font-black !text-white">
                @product.Tag
            </div>

            <a href="@product.Url" class="block aspect-square bg-neutral-100 p-5">
                <div class="flex h-full items-center justify-center rounded-[1.25rem] bg-white text-center">
                    <img src="@product.ImageUrl"
                         alt="@product.Name"
                         class="max-h-full max-w-full object-contain transition duration-500 group-hover:scale-105" />
                </div>
            </a>

            <div class="!p-5">

                <h3 class="min-h-12 overflow-hidden text-sm leading-6 font-black tracking-[-0.02em] uppercase">
                    <a href="@product.Url" class="transition hover:text-[#d71920]">
                        @product.Name
                    </a>
                </h3>

                <div class="mt-4 flex flex-wrap items-center gap-2">
                    <p class="text-lg font-black text-[#d71920]">
                        @product.Price
                    </p>

                    @if (!string.IsNullOrWhiteSpace(product.OldPrice))
                    {
                        <p class="text-sm font-bold text-neutral-400 line-through">
                            @product.OldPrice
                        </p>
                    }
                </div>

                <div class="mt-5 grid grid-cols-2 gap-2">
                    <button class="!rounded-full !border !border-neutral-300 !px-3 !py-2 text-xs font-black uppercase transition hover:!border-neutral-950">
                        Xem nhanh
                    </button>

                    <button class="!rounded-full !bg-neutral-950 !px-3 !py-2 text-xs font-black !text-white uppercase transition hover:bg-[#d71920]">
                        Chọn
                    </button>
                </div>
            </div>
        </article>;
    }
}