    };

    private TeamMember[] _teamMembers = new TeamMember[]
    {
        new TeamMember("Ben Johns", "https://joola.com.vn/images/236/thumbs/ben-johns-a991b0c5-f33f-4001-ba12-6f1543b033d2-495x796xcrop.webp", "Triple Crown, kiểm soát bóng và sức mạnh ở đẳng cấp thi đấu chuyên nghiệp."),
        new TeamMember("Anna Bright", "https://joola.com.vn/images/237/thumbs/anna-bright-495x796xcrop.webp", "Phong cách thi đấu tốc độ, linh hoạt và giàu năng lượng trên sân."),
        new TeamMember("Tyson McGuffin", "https://joola.com.vn/images/238/thumbs/tyson-mcguffin-495x796xcrop.webp", "Biểu tượng thi đấu mạnh mẽ, truyền cảm hứng cho cộng đồng pickleball."),
        new TeamMember("Dekel Bar", "https://joola.com.vn/images/239/thumbs/dekel-bar-495x796xcrop.webp", "Vận động viên chuyên nghiệp với khả năng tấn công bền bỉ và chính xác.")
    };

    private BlogPost[] _blogPosts = new BlogPost[]
    {
        new BlogPost(
            "Razer và PickleChic ra mắt vợt Pickleball phiên bản giới hạn",
