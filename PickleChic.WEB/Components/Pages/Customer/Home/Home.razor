@page "/"
@layout MainLayout

<PageTitle>PickleChic Store</PageTitle>

<div class="pc-home bg-white text-neutral-950">
    <section class="bg-neutral-950">
        <MudCarousel TData="HeroSlide"
                     Class="mud-width-full"
                     Style="height: 620px;"
                     AutoCycle="true"
                     AutoCycleTime="TimeSpan.FromSeconds(5)"
                     ShowArrows="true"
                     ShowBullets="true"
                     EnableSwipeGesture="true">
            @foreach (var slide in HeroSlides)
            {
                <MudCarouselItem>
                    <div class="relative h-[620px] overflow-hidden bg-neutral-950">
                        <img src="@slide.ImageUrl"
                             alt="@slide.Title"
                             class="absolute inset-0 h-full w-full object-cover" />

                        <div class="bg-gradient-to-r absolute inset-0 from-black via-black/75 to-black/20"></div>

                        <div class="relative mx-auto flex h-full max-w-7xl items-center px-4">
                            <div class="max-w-3xl text-white">
                                <p class="mb-4 inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-black tracking-[0.28em] text-white/80 uppercase backdrop-blur">
                                    @slide.Eyebrow
                                </p>

                                <h1 class="text-5xl leading-[0.92] font-black tracking-[-0.07em] uppercase sm:text-6xl lg:text-7xl">
                                    @slide.Title
                                </h1>

                                <p class="mt-6 max-w-xl text-base leading-7 text-neutral-300 sm:text-lg">
                                    @slide.Description
                                </p>

                                <div class="mt-8 flex flex-wrap gap-3">
                                    <MudButton Href="@slide.Url"
                                               Variant="Variant.Filled"
                                               Color="Color.Error"
                                               Size="Size.Large"
                                               Class="!rounded-full !px-7 !py-3 !text-sm !font-black !tracking-wide !uppercase">
                                        Xem sản phẩm
                                    </MudButton>

                                    <MudButton Href="#new-products"
                                               Variant="Variant.Outlined"
                                               Color="Color.Default"
                                               Size="Size.Large"
                                               Class="!rounded-full !border-white/30 !px-7 !py-3 !text-sm !font-black !tracking-wide !text-white !uppercase">
                                        Sản phẩm mới
                                    </MudButton>
                                </div>
                            </div>
                        </div>
                    </div>
                </MudCarouselItem>
            }
        </MudCarousel>
    </section>

    <section class="border-b border-neutral-200 bg-neutral-100">
        <div class="mx-auto grid max-w-7xl gap-0 px-4 py-9 sm:grid-cols-2 lg:grid-cols-4">
            @foreach (var item in _serviceBenefits)
            {
                <div class="flex gap-5 border-neutral-300 px-2 py-4 lg:border-r lg:last:border-r-0">
                    <div class="shrink-0 text-neutral-950">
                        <MudIcon Icon="@item.Icon" Size="Size.Large" />
                    </div>

                    <div>
                        <h3 class="text-base font-black text-neutral-950 capitalize">
                            @item.Title
                        </h3>

                        <p class="mt-3 max-w-[220px] text-sm leading-6 font-medium text-neutral-600">
                            @item.Description
                        </p>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="mx-auto grid max-w-7xl gap-4 !px-4 !py-12 sm:grid-cols-2 lg:grid-cols-4">
        @foreach (var category in _categories)
        {
            <a href="@category.Url" class="group overflow-hidden !rounded-3xl bg-neutral-100 !p-6 transition hover:!text-white hover:-translate-y-1 hover:bg-neutral-950 hover:shadow-xl">
                <p class="text-xs font-black tracking-[0.28em] text-[#d71920] uppercase">
                    @category.Eyebrow
                </p>

                <h3 class="mt-4 text-2xl font-black tracking-[-0.04em] uppercase">
                    @category.Name
                </h3>

                <p class="mt-8 text-sm font-bold text-neutral-500 transition group-hover:text-neutral-300">
                    Xem chi tiết →
                </p>
            </a>
        }
    </section>

    <section class="mx-auto max-w-7xl !px-4 !pb-14">
        <div class="grid overflow-hidden !rounded-[2rem] bg-neutral-950 !text-white md:grid-cols-[1.1fr_0.9fr]">
            <div class="!p-8 md:!p-12">
                <p class="text-xs font-black tracking-[0.3em] text-[#d71920] uppercase">
                    Công nghệ thế hệ mới
                </p>

                <h2 class="mt-3 max-w-xl text-4xl leading-none font-black tracking-[-0.06em] uppercase md:text-5xl">
                    Pro IV Colorway dành cho người chơi nghiêm túc
                </h2>

                <p class="mt-5 max-w-xl text-sm leading-7 text-neutral-300">
                    Thiết kế đậm chất thi đấu, tối ưu sức mạnh, độ xoáy và kiểm soát bóng.
                    Phù hợp cho người chơi muốn nâng cấp trải nghiệm pickleball chuyên nghiệp.
                </p>

                <a href="#best-sellers" class="mt-8 inline-flex !rounded-full bg-[#d71920] !px-7 !py-3 text-sm font-black tracking-wide !text-white uppercase transition hover:bg-white hover:text-neutral-950">
                    Khám phá ngay
                </a>
            </div>

            <div class="bg-gradient-to-br relative min-h-[320px] from-neutral-900 to-neutral-800">
                <img src="https://joola.com.vn/images/1102/thumbs/joola-ra-mat-vot-pickleball-pro-iv-va-agassi-pro-duoc-chung-nhan-kep-w900.webp"
                     alt="PickleChic Pro IV"
                     class="h-full w-full object-cover opacity-90" />
            </div>
        </div>
    </section>

    <section id="new-products" class="bg-white py-16 text-neutral-950 lg:py-20">
        <div class="mx-auto max-w-7xl px-4">
            @SectionHeading("New arrivals", "Sản phẩm mới", "Xem tất cả", "/products/new")

            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
                @foreach (var product in _newProducts)
                {
                    @ProductCard(product)
                }
            </div>
        </div>
    </section>

    <section id="best-sellers" class="bg-neutral-950 !py-16 !text-white lg:!py-20">
        <div class="mx-auto max-w-7xl !px-4">
            @SectionHeading("Best sellers", "Sản phẩm bán chạy", "Xem tất cả", "/products/best-sellers")

            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
                @foreach (var product in _bestSellerProducts)
                {
                    @ProductCard(product)
                }
            </div>
        </div>
    </section>

    <section id="team-picklechic" class="bg-neutral-100 !py-16 lg:!py-24">
        <div class="mx-auto max-w-7xl !px-4">
            @SectionHeading("Athletes", "TEAM PICKLECHIC", "Xem tất cả", "/team")

            <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
                @foreach (var member in _teamMembers)
                {
                    <article class="group overflow-hidden rounded-[1.75rem] bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
                        <div class="aspect-[4/5] bg-neutral-900">
                            <img src="@member.ImageUrl"
                                 alt="@member.Name"
                                 class="h-full w-full object-cover opacity-95 transition duration-500 group-hover:scale-105" />
                        </div>

                        <div class="!p-6">
                            <h3 class="text-xl font-black tracking-[-0.04em] uppercase">
                                @member.Name
                            </h3>

                            <p class="mt-3 text-sm leading-6 font-semibold text-neutral-600">
                                @member.Highlight
                            </p>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="bg-white !py-16 lg:!py-24">
        <div class="mx-auto max-w-7xl !px-4">
            @SectionHeading("PickleChic News", "Blog - Tin tức", "Xem tất cả", "/blog")

            <div class="grid gap-6 md:grid-cols-3">
                @foreach (var post in _blogPosts)
                {
                    <article class="group overflow-hidden !rounded-[1.75rem] !border !border-neutral-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
                        <a href="@post.Url" class="block aspect-[16/10] overflow-hidden bg-neutral-100">
                            <img src="@post.ImageUrl"
                                 alt="@post.Title"
                                 class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
                        </a>

                        <div class="!p-6">
                            <div class="flex items-center gap-3 text-xs font-black tracking-[0.18em] text-[#d71920] uppercase">
                                <span>@post.Category</span>
                                <span class="h-1 w-1 !rounded-full bg-neutral-300"></span>
                                <span class="text-neutral-400">@post.DateText</span>
                            </div>

                            <h3 class="mt-4 min-h-[72px] text-xl leading-6 font-black tracking-[-0.04em] text-neutral-950 uppercase">
                                <a href="@post.Url" class="transition hover:text-[#d71920]">
                                    @post.Title
                                </a>
                            </h3>

                            <p class="mt-4 text-sm leading-6 font-medium text-neutral-600">
                                @post.Description
                            </p>

                            <a href="@post.Url" class="mt-5 inline-flex text-sm font-black tracking-wide text-neutral-950 uppercase transition hover:text-[#d71920]">
                                Đọc tiếp →
                            </a>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
</div>

@code {
    private class HeroSlide
    {
        public string Eyebrow { get; set; }
        public string Title { get; set; }
        public string Description { get; set; }
        public string ImageUrl { get; set; }
        public string Url { get; set; }

        public HeroSlide(string eyebrow, string title, string description, string imageUrl, string url)
        {
            Eyebrow = eyebrow;
            Title = title;
            Description = description;
            ImageUrl = imageUrl;
            Url = url;
        }
    }

    private class ServiceBenefit
    {
        public string Icon { get; set; }
        public string Title { get; set; }
        public string Description { get; set; }

        public ServiceBenefit(string icon, string title, string description)
        {
            Icon = icon;
            Title = title;
            Description = description;
        }
    }

    private class CategoryItem
    {
        public string Eyebrow { get; set; }
        public string Name { get; set; }
        public string Url { get; set; }

        public CategoryItem(string eyebrow, string name, string url)
        {
            Eyebrow = eyebrow;
            Name = name;
            Url = url;
        }
    }

    private class ProductItem
    {
        public string Name { get; set; }
        public string ImageUrl { get; set; }
        public string Price { get; set; }
        public string OldPrice { get; set; }
        public int Discount { get; set; }
        public int Reviews { get; set; }
        public string Tag { get; set; }
        public string Url { get; set; }

        public ProductItem(string name, string imageUrl, string price, string oldPrice, int discount, int reviews, string tag, string url)
        {
            Name = name;
            ImageUrl = imageUrl;
            Price = price;
            OldPrice = oldPrice;
            Discount = discount;
            Reviews = reviews;
            Tag = tag;
            Url = url;
        }
    }

    private class TeamMember
    {
        public string Name { get; set; }
        public string ImageUrl { get; set; }
        public string Highlight { get; set; }

        public TeamMember(string name, string imageUrl, string highlight)
        {
            Name = name;
            ImageUrl = imageUrl;
            Highlight = highlight;
        }
    }

    private class BlogPost
    {
        public string Title { get; set; }
        public string Category { get; set; }
        public string DateText { get; set; }
        public string Description { get; set; }
        public string ImageUrl { get; set; }
        public string Url { get; set; }

        public BlogPost(string title, string category, string dateText, string description, string imageUrl, string url)
        {
            Title = title;
            Category = category;
            DateText = dateText;
            Description = description;
            ImageUrl = imageUrl;
            Url = url;
        }
    }

