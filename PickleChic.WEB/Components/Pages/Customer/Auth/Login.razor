@attribute [Route(RouterConfig.Customer.Login)]
@layout MainLayout

<PageTitle>@Constant.metaDataCustomer Login</PageTitle>

<div class="!bg-slate-50 !px-4 !pt-10 !pb-14">
    <div class="mx-auto grid w-full max-w-5xl items-start !gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <section class="hidden lg:block">
            <div class="!rounded-3xl !border !border-slate-200 !bg-white !p-9 shadow-sm">
                <div>
                    <p class="text-sm font-bold tracking-[0.25em] text-red-600 uppercase">
                        PickleChic WEB
                    </p>

                    <h1 class="!mt-4 max-w-xl text-4xl leading-tight font-bold tracking-tight text-slate-900">
                        Đăng nhập để tiếp tục mua sắm
                    </h1>

                    <p class="!mt-4 max-w-lg text-base leading-7 text-slate-500">
                        Theo dõi đơn hàng, quản lý địa chỉ, lưu sản phẩm yêu thích và nhận ưu đãi dành riêng cho bạn.
                    </p>
                </div>

                <div class="!mt-10 grid !gap-4 sm:grid-cols-3">
                    <div class="!rounded-2xl !border !border-slate-200 !bg-slate-50 !p-5">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping"
                                 Class="text-red-600" />
                        <p class="!mt-3 text-sm font-semibold text-slate-900">Theo dõi đơn</p>
                    </div>

                    <div class="!rounded-2xl !border !border-slate-200 !bg-slate-50 !p-5">
                        <MudIcon Icon="@Icons.Material.Filled.Favorite"
                                 Class="text-red-600" />
                        <p class="!mt-3 text-sm font-semibold text-slate-900">Yêu thích</p>
                    </div>

                    <div class="!rounded-2xl !border !border-slate-200 !bg-slate-50 !p-5">
                        <MudIcon Icon="@Icons.Material.Filled.CardGiftcard"
                                 Class="text-red-600" />
                        <p class="!mt-3 text-sm font-semibold text-slate-900">Ưu đãi</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="mx-auto w-full max-w-md lg:mx-0">
            <div class="!rounded-3xl !border !border-slate-200 !bg-white !p-8 shadow-sm">
                <div class="text-center">
                    <h1 class="!mt-3 text-2xl font-bold tracking-tight text-slate-900">
                        Đăng nhập
                    </h1>

                    <p class="!mt-2 text-sm text-slate-500">
                        Chào mừng bạn quay lại
                    </p>
                </div>

                <MudForm @ref="_form"
                         Model="@_model"
                         Validation="@_validator.ValidateValue">
                    <div class="!mt-8 !space-y-5">
                        <MudTextField @bind-Value="_model.Email"
                                      For="@(() => _model.Email)"
                                      Label="Email"
                                      Placeholder="Nhập email của bạn"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Email"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email"
                                      Required="true"
                                      Immediate="true" />

                        <MudTextField @bind-Value="_model.Password"
                                      For="@(() => _model.Password)"
                                      Label="Mật khẩu"
                                      Placeholder="Nhập mật khẩu"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Password"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Lock"
                                      Required="true"
                                      Immediate="true" />

                        <div class="flex items-center justify-between !gap-3">
                            <label class="flex cursor-pointer items-center !gap-2 text-sm text-slate-600">
                                <input type="checkbox"
                                       class="!h-4 !w-4 !rounded !border-slate-300" />
                                Ghi nhớ đăng nhập
                            </label>

                            <a href="@RouterConfig.Customer.ForgotPassword"
                               class="text-sm font-semibold text-slate-900 transition hover:text-red-600">
                                Quên mật khẩu?
                            </a>
                        </div>

                        <button type="button"
                                @onclick="SubmitAsync"
                                class="inline-flex w-full items-center justify-center !gap-2 !rounded-full !bg-black !px-6 !py-3 text-sm font-bold !text-white shadow-sm transition hover:!bg-red-600 hover:!text-white">
                            <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Small" />
                            Đăng nhập
                        </button>
                    </div>
                </MudForm>

                <div class="!mt-6 text-center">
                    <p class="text-sm text-slate-500">
                        Chưa có tài khoản?
                        <a href="@RouterConfig.Customer.SignUp"
                           class="font-semibold text-slate-900 transition hover:text-red-600">
                            Đăng ký ngay
                        </a>
                    </p>
                </div>
            </div>
        </section>
    </div>
</div>

@code {
    private MudForm? _form;

    private readonly LoginModel _model = new();

    private readonly LoginSchema.Login _validator = new();

    private async Task SubmitAsync()
    {
        if (_form is null)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        _navigation.NavigateTo(RouterConfig.Customer.Home);
    }
}