@attribute [Route(RouterConfig.Customer.SignUp)]
@layout MainLayout

<PageTitle>PickleChic WEB - Register</PageTitle>

<div class="min-h-[calc(100vh-180px)] !bg-slate-50 !px-4 !pt-10 !pb-14">
    <div class="mx-auto w-full max-w-4xl">
        <div class="!rounded-3xl !border !border-slate-200 !bg-white !p-6 shadow-sm md:!p-10">
            <div class="mx-auto max-w-2xl text-center">
                <p class="text-sm font-bold tracking-[0.25em] text-red-600 uppercase">
                    PickleChic WEB
                </p>

                <h1 class="!mt-3 text-3xl font-bold tracking-tight text-slate-900">
                    Đăng ký tài khoản
                </h1>

                <p class="!mt-3 text-sm leading-6 text-slate-500">
                    Tạo tài khoản để theo dõi đơn hàng, lưu sản phẩm yêu thích và nhận ưu đãi dành riêng cho bạn.
                </p>
            </div>

            <MudForm @ref="_form"
                     Model="@_model"
                     Validation="@_validator.ValidateValue">
                <div class="!mt-8 grid !gap-5 md:grid-cols-2">
                    <MudTextField @bind-Value="_model.FullName"
                                  For="@(() => _model.FullName)"
                                  Label="Họ tên"
                                  Placeholder="Nhập họ tên"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person"
                                  Required="true"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_model.Email"
                                  For="@(() => _model.Email)"
                                  Label="Email"
                                  Placeholder="Nhập email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Required="true"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_model.PhoneNumber"
                                  For="@(() => _model.PhoneNumber)"
                                  Label="Số điện thoại"
                                  Placeholder="Nhập số điện thoại"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Phone"
                                  Required="true"
                                  Immediate="true" />

                    <MudDatePicker @bind-Date="_model.DateOfBirth"
                                   For="@(() => _model.DateOfBirth)"
                                   Label="Ngày sinh"
                                   Placeholder="Chọn ngày sinh"
                                   Variant="Variant.Outlined"
                                   AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                                   Required="true" />

                    <MudSelect T="string"
                               @bind-Value="_model.Gender"
                               For="@(() => _model.Gender)"
                               Label="Giới tính"
                               Placeholder="Chọn giới tính"
                               Variant="Variant.Outlined"
                               AdornmentIcon="@Icons.Material.Filled.Wc"
                               Required="true">
                        <MudSelectItem T="string" Value="@("Nam")">Nam</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Nữ")">Nữ</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Khác")">Khác</MudSelectItem>
                    </MudSelect>

                    <div class="hidden md:block"></div>

                    <MudTextField @bind-Value="_model.Password"
                                  For="@(() => _model.Password)"
                                  Label="Mật khẩu"
                                  Placeholder="Nhập mật khẩu"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Required="true"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_model.ConfirmPassword"
                                  For="@(() => _model.ConfirmPassword)"
                                  Label="Xác nhận mật khẩu"
                                  Placeholder="Nhập lại mật khẩu"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.LockReset"
                                  Required="true"
                                  Immediate="true" />
                </div>

                <div class="!mt-8 flex flex-col-reverse !gap-4 border-t !border-slate-200 !pt-6 md:flex-row md:items-center md:justify-between">
                    <p class="text-center text-sm text-slate-500 md:text-left">
                        Đã có tài khoản?
                        <a href="@RouterConfig.Customer.Login"
                           class="font-semibold text-slate-900 transition hover:text-red-600">
                            Đăng nhập
                        </a>
                    </p>

                    <button type="button"
                            @onclick="SubmitAsync"
                            class="inline-flex items-center justify-center !gap-2 !rounded-full !border !border-black !bg-black !px-8 !py-3 text-sm font-bold !text-white shadow-sm transition hover:!border-red-600 hover:!bg-red-600 hover:!text-white">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" />
                        Đăng ký
                    </button>
                </div>
            </MudForm>
        </div>
    </div>
</div>

@code {
    private MudForm? _form;

    private readonly RegisterModel _model = new();

    private readonly RegisterSchema.Register _validator = new();

    private async Task SubmitAsync()
    {
        if (_form is null)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        // TODO: Gọi API đăng ký customer tại đây.
        // await AuthService.RegisterAsync(_model);

        _navigation.NavigateTo(RouterConfig.Customer.Login);
    }
}