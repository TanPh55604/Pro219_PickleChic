@attribute [Route(RouterConfig.Admin.Login)]
@layout PublicLayout

<PageTitle>@Constant.metaDataAdmin Login</PageTitle>

<div class="flex min-h-screen w-full items-center justify-center !bg-slate-100 !px-4 !py-10">
    <div class="w-full max-w-md">
        <div class="!rounded-3xl !border !border-slate-200 !bg-white !p-8 shadow-sm">
            <div class="flex flex-col items-center text-center">
                <div class="flex !h-14 !w-14 items-center justify-center !rounded-2xl !bg-slate-900 !text-white shadow-sm">
                    <span class="text-xl font-bold">P</span>
                </div>

                <h1 class="!mt-5 text-2xl font-bold tracking-tight text-slate-900">
                    PICKLECHIC
                </h1>

                <p class="!mt-1 text-sm text-slate-500">
                    PickleChic Management
                </p>
            </div>

            <MudForm @ref="_form"
                     Model="@_model"
                     Validation="@_validator.ValidateValue">
                <div class="!mt-8 !space-y-5">
                    <MudTextField @bind-Value="_model.Email"
                                  For="@(() => _model.Email)"
                                  Label="Email"
                                  Placeholder="Nhập email quản trị"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Required="true"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_model.Password"
                                  For="@(() => _model.Password)"
                                  Label="Mật khẩu"
                                  Placeholder="Nhập mật khẩu"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Required="true"
                                  Immediate="true" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Dark"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Login"
                               OnClick="SubmitAsync"
                               Class="!rounded-xl !py-3 !normal-case">
                        Đăng nhập
                    </MudButton>
                </div>
            </MudForm>
        </div>

        <p class="!mt-5 text-center text-xs text-slate-400">
            © @DateTime.Now.Year PickleChic Management
        </p>
    </div>
</div>

@code {
    private MudForm? _form;

    private readonly AdminLoginModel _model = new();

    private readonly AdminLoginSchema.Login _validator = new();

    private async Task SubmitAsync()
    {
        if (_form is null)
        {
            return;
        }

        await _form.Validate();

        if (!_form.IsValid)
        {
            return;
        }

        // TODO: Gọi API đăng nhập admin tại đây.
        // await AuthService.AdminLoginAsync(_model);

        _navigation.NavigateTo(RouterConfig.Admin.Home);
    }
}