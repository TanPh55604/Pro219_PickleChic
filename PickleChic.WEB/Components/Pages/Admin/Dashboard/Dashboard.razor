@page "/admin/dashboard"
@layout AdminLayout

<PageTitle>PickleChic Management - Dashboard</PageTitle>

<div class="!space-y-6">
    <div>
        <h2 class="text-2xl font-bold text-slate-900">Tổng quan</h2>
        <p class="mt-1 text-slate-500">
            Theo dõi nhanh tình hình bán hàng và hoạt động hệ thống.
        </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        <div class="!rounded-2xl !border !border-slate-200 !bg-white !p-5 shadow-sm">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-slate-500">Doanh thu</p>
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="text-slate-500" />
            </div>

            <p class="mt-4 text-2xl font-bold text-slate-900">24.500.000đ</p>
            <p class="mt-1 text-sm text-emerald-600">+12% so với tháng trước</p>
        </div>

        <div class="!rounded-2xl !border !border-slate-200 !bg-white !p-5 shadow-sm">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-slate-500">Đơn hàng</p>
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="text-slate-500" />
            </div>

            <p class="mt-4 text-2xl font-bold text-slate-900">128</p>
            <p class="mt-1 text-sm text-emerald-600">+8 đơn hôm nay</p>
        </div>

        <div class="!rounded-2xl !border !border-slate-200 !bg-white !p-5 shadow-sm">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-slate-500">Sản phẩm</p>
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="text-slate-500" />
            </div>

            <p class="mt-4 text-2xl font-bold text-slate-900">356</p>
            <p class="mt-1 text-sm text-slate-500">Đang hoạt động</p>
        </div>

        <div class="!rounded-2xl !border !border-slate-200 !bg-white !p-5 shadow-sm">
            <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-slate-500">Khách hàng</p>
                <MudIcon Icon="@Icons.Material.Filled.Groups" Class="text-slate-500" />
            </div>

            <p class="mt-4 text-2xl font-bold text-slate-900">1.204</p>
            <p class="mt-1 text-sm text-emerald-600">+34 khách mới</p>
        </div>
    </div>

    <div class="grid gap-5 xl:grid-cols-3">
        <div class="!rounded-2xl !border !border-slate-200 !bg-white !p-5 shadow-sm xl:col-span-2">
            <div class="mb-4 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-slate-900">Đơn hàng gần đây</h3>

                <a href="/admin/orders"
                   class="text-sm font-medium text-slate-700 hover:text-slate-950">
                    Xem tất cả
                </a>
            </div>

            <div class="overflow-hidden !rounded-xl !border !border-slate-200">
                <table class="w-full text-left text-sm">
                    <thead class="!bg-slate-50 text-slate-500">
                        <tr>
                            <th class="!px-4 !py-3 font-medium">Mã đơn</th>
                            <th class="!px-4 !py-3 font-medium">Khách hàng</th>
                            <th class="!px-4 !py-3 font-medium">Tổng tiền</th>
                            <th class="!px-4 !py-3 font-medium">Trạng thái</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-200 !bg-white">
                        <tr>
                            <td class="!px-4 !py-3 font-medium text-slate-900">#DH001</td>
                            <td class="!px-4 !py-3 text-slate-600">Nguyễn Văn A</td>
                            <td class="!px-4 !py-3 text-slate-600">1.250.000đ</td>
                            <td class="!px-4 !py-3">
                                <span class="!rounded-full !bg-emerald-50 !px-3 !py-1 text-xs font-medium text-emerald-700">
                                    Hoàn thành
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <td class="!px-4 !py-3 font-medium text-slate-900">#DH002</td>
                            <td class="!px-4 !py-3 text-slate-600">Trần Thị B</td>
                            <td class="!px-4 !py-3 text-slate-600">850.000đ</td>
                            <td class="!px-4 !py-3">
                                <span class="!rounded-full !bg-amber-50 !px-3 !py-1 text-xs font-medium text-amber-700">
                                    Đang xử lý
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <td class="!px-4 !py-3 font-medium text-slate-900">#DH003</td>
                            <td class="!px-4 !py-3 text-slate-600">Lê Văn C</td>
                            <td class="!px-4 !py-3 text-slate-600">2.100.000đ</td>
                            <td class="!px-4 !py-3">
                                <span class="!rounded-full !bg-sky-50 !px-3 !py-1 text-xs font-medium text-sky-700">
                                    Đang giao
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="!rounded-2xl !border !border-slate-200 !bg-white !p-5 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">Ghi chú quản trị</h3>

            <div class="mt-4 space-y-3">
                <div class="!rounded-xl !bg-slate-50 !p-4">
                    <p class="text-sm font-medium text-slate-800">Kiểm tra tồn kho</p>
                    <p class="mt-1 text-sm text-slate-500">
                        Có 12 sản phẩm sắp hết hàng.
                    </p>
                </div>

                <div class="!rounded-xl !bg-slate-50 !p-4">
                    <p class="text-sm font-medium text-slate-800">Đơn chờ xử lý</p>
                    <p class="mt-1 text-sm text-slate-500">
                        Cần xác nhận 5 đơn mới.
                    </p>
                </div>

                <div class="!rounded-xl !bg-slate-50 !p-4">
                    <p class="text-sm font-medium text-slate-800">Báo cáo doanh thu</p>
                    <p class="mt-1 text-sm text-slate-500">
                        Cập nhật dữ liệu trong ngày.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>