@using MudBlazor

<div class="bg-black text-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between !px-4 !py-2 font-bold tracking-[0.22em] text-[11px] text-white/80 uppercase">
        <p>PickleChic Store</p>

        <div class="hidden items-center !gap-5 sm:flex">
            <span>Hotline: 0900 000 000</span>
            <a href="#" class="transition hover:!text-white">Hệ thống cửa hàng</a>
        </div>
    </div>
</div>

<header class="sticky top-0 z-50 !border-b !border-neutral-200 bg-white/95 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between !px-4 !py-4">
        <a href="@RouterConfig.Customer.Home" class="flex items-center !gap-3">
            <div class="flex !h-11 !w-11 items-center justify-center !rounded-full !bg-[#d71920] text-lg font-black !text-white">
                P
            </div>

            <div>
                <p class="text-2xl leading-none font-black tracking-[-0.06em] text-neutral-900 uppercase">
                    PickleChic
                </p>
                <p class="!mt-1 font-bold tracking-[0.24em] text-[10px] text-neutral-500 uppercase">
                    Pickleball Việt Nam
                </p>
            </div>
        </a>

        <nav class="hidden items-center !gap-8 text-sm font-black tracking-wide uppercase lg:flex">
            @foreach (var item in _menuItems)
            {
                <a href="@item.Url" class="group relative !py-2 text-neutral-900 transition hover:!text-[#d71920]">
                    @item.Name
                    <span class="absolute inset-x-0 -bottom-1 !h-0.5 origin-left scale-x-0 !bg-[#d71920] transition group-hover:scale-x-100"></span>
                </a>
            }
        </nav>

        <div class="flex items-center !gap-2">
            <button class="hidden !rounded-full !border !border-neutral-300 !px-5 !py-2.5 text-sm font-black transition hover:!border-[#d71920] hover:!text-[#d71920] sm:!inline-flex">
                Tìm kiếm
            </button>

            <a href="@RouterConfig.Customer.Cart"
               class="!rounded-full !bg-neutral-950 !px-5 !py-2.5 text-sm font-black !text-white transition hover:!bg-[#d71920]">
                Giỏ hàng
            </a>

            @if (!_isAuthenticated)
            {
                <a href="@RouterConfig.Customer.Login"
                   class="inline-flex !h-11 !w-11 items-center justify-center !rounded-full !border !border-neutral-300 text-neutral-900 transition hover:!border-[#d71920] hover:!bg-[#d71920] hover:!text-white"
                   title="Đăng nhập">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                </a>
            }
            else
            {
                <MudMenu AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         Dense="true">
                    <ActivatorContent>
                        <button class="inline-flex !h-11 !w-11 items-center justify-center !rounded-full !border !border-neutral-300 text-neutral-900 transition hover:!border-[#d71920] hover:!bg-[#d71920] hover:!text-white">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        </button>
                    </ActivatorContent>

                    <ChildContent>
                        <div class="min-w-56 !px-4 !py-3">
                            <p class="text-sm font-bold text-neutral-900">@_customerName</p>
                            <p class="!mt-1 text-xs text-neutral-500">@_customerEmail</p>
                        </div>

                        <MudDivider />

                        <MudMenuItem Href="@RouterConfig.Customer.Profile"
                                     Icon="@Icons.Material.Filled.AccountCircle">
                            Thông tin tài khoản
                        </MudMenuItem>

                        <MudMenuItem Href="@RouterConfig.Customer.Orders"
                                     Icon="@Icons.Material.Filled.ReceiptLong">
                            Đơn hàng của tôi
                        </MudMenuItem>

                        <MudDivider />

                        <MudMenuItem Icon="@Icons.Material.Filled.Logout"
                                     OnClick="LogoutAsync">
                            Đăng xuất
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
            }
        </div>
    </div>
</header>

@code {
    private bool _isAuthenticated = false;

    private string _customerName = "Nguyễn Văn A";
    private string _customerEmail = "customer@gmail.com";

    private class NavItem
    {
        public string Name { get; set; }
        public string Url { get; set; }

        public NavItem(string name, string url)
        {
            Name = name;
            Url = url;
        }
    }

    private NavItem[] _menuItems =
    {
        new("Trang chủ", RouterConfig.Customer.Home),
        new("Sản phẩm", RouterConfig.Customer.Products),
        new("Giới thiệu", RouterConfig.Customer.About),
        new("Liên hệ", RouterConfig.Customer.Contact)
    };

    private async Task LogoutAsync()
    {
        // TODO: Gọi API/logout service tại đây.
        // await AuthService.LogoutAsync();

        _isAuthenticated = false;

        _navigation.NavigateTo(RouterConfig.Customer.Home);
    }
}